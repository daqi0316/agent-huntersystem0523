> """LLM 简历结构化抽取服务 — 纯文本 → 候选人的结构化字段。"""
  
> import json
> import logging
  
> from app.llm.omlx_client import OMLXClient
> from app.schemas.resume import ExtractedCandidate
  
> logger = logging.getLogger(__name__)
  
  
> EXTRACT_SYSTEM_PROMPT = """你是一位专业的简历解析助手。你的任务是从简历文本中提取关键信息，以 JSON 格式返回。
  
> 请严格按照以下 JSON 格式返回（不要包含 markdown 代码标记）：
  
> {
>   "name": "候选人姓名",
>   "email": "邮箱",
>   "phone": "电话",
>   "summary": "个人简介（2-3句话概括）",
>   "skills": ["技能1", "技能2", ...],
>   "experience_years": 工作经验年数（纯数字，没有就 null）,
>   "education": "教育背景（学历+学校+专业）",
>   "current_company": "当前公司名称",
>   "current_title": "当前职位名称"
> }
  
> 注意事项：
> - 如果某个字段在简历中不存在，请使用空字符串 "" 或 null
> - experience_years 只返回数字，无法推断则返回 null
> - skills 是从简历中提取的技能关键词列表
> - summary 是对候选人职业背景的简要概括
> - 如果简历内容看起来不是中文简历，请仍然尽力提取并返回 JSON
> - 只返回 JSON，不要有其他文字说明
> """
  
  
> async def extract_from_text(
>     resume_text: str,
>     llm: OMLXClient | None = None,
> ) -> ExtractedCandidate:
>     """用 LLM 从简历文本中抽取结构化候选人信息。"""
!     if llm is None:
!         llm = OMLXClient()
  
!     messages = [
!         {"role": "system", "content": EXTRACT_SYSTEM_PROMPT},
!         {
!             "role": "user",
!             "content": f"请从以下简历中提取关键信息：\n\n{resume_text[:8000]}",
!         },
!     ]
  
!     raw = await llm.chat(messages, raise_on_error=True)
  
      # 清理 LLM 输出（可能包含 markdown 代码块标记）
!     cleaned = raw.strip()
!     if cleaned.startswith("```"):
          # 移除 ```json ... ``` 包裹
!         cleaned = cleaned.split("\n", 1)[-1]
!         cleaned = cleaned.rsplit("```", 1)[0].strip()
!     if cleaned.startswith("json"):
!         cleaned = cleaned[4:].strip()
  
!     try:
!         data = json.loads(cleaned)
!     except json.JSONDecodeError:
!         logger.warning("LLM returned invalid JSON, attempting fallback parse: %s", raw[:200])
          # 尝试从文本中提取 JSON 片段
!         import re
  
!         match = re.search(r"\{.*\}", cleaned, re.DOTALL)
!         if match:
!             try:
!                 data = json.loads(match.group())
!             except json.JSONDecodeError:
!                 data = _fallback_extract(resume_text)
!         else:
!             data = _fallback_extract(resume_text)
  
!     return ExtractedCandidate(
!         name=data.get("name", "") or "",
!         email=data.get("email", "") or "",
!         phone=data.get("phone", "") or "",
!         summary=data.get("summary", "") or "",
!         skills=data.get("skills", []) or [],
!         experience_years=data.get("experience_years"),
!         education=data.get("education", "") or "",
!         current_company=data.get("current_company", "") or "",
!         current_title=data.get("current_title", "") or "",
!         raw_text=resume_text,
!     )
  
  
