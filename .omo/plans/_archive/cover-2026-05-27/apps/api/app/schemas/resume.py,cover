> """简历导入相关 Pydantic schemas。"""
  
> from datetime import datetime
  
> from pydantic import BaseModel, Field
  
  
> class ResumeUploadResponse(BaseModel):
>     """文件上传并解析后的响应"""
  
>     success: bool = True
>     filename: str = ""
>     file_size: int = 0
>     text_length: int = 0
>     plain_text: str = ""  # 解析出的纯文本
  
  
> class ExtractedCandidate(BaseModel):
>     """LLM 从简历中提取的结构化候选人信息"""
  
>     name: str = Field("", description="候选人姓名")
>     email: str = Field("", description="邮箱")
>     phone: str = Field("", description="电话")
>     summary: str = Field("", description="个人简介/概要")
>     skills: list[str] = Field(default_factory=list, description="技能列表")
>     experience_years: int | None = Field(None, description="工作经验年数")
>     education: str = Field("", description="教育背景")
>     current_company: str = Field("", description="当前公司")
>     current_title: str = Field("", description="当前职位")
>     raw_text: str = Field("", description="原始简历文本")
  
  
> class ResumeExtractResponse(BaseModel):
>     """简历解析+抽取完成后的响应"""
  
>     success: bool = True
>     filename: str = ""
>     text_length: int = 0
>     candidate: ExtractedCandidate | None = None
>     needs_review: bool = False
  
  
> class ResumeConfirmCreate(BaseModel):
>     """用户确认后创建候选人的请求"""
  
>     parsed: ExtractedCandidate
>     create_candidate: bool = True
>     run_screening: bool = False
>     job_id: str | None = None
  
  
> class ResumeConfirmResponse(BaseModel):
>     """确认创建候选人后的响应"""
  
>     success: bool = True
>     candidate_id: str = ""
>     candidate_name: str = ""
>     screening_result: dict | None = None
>     message: str = ""
