> """Structured memory fact — records what the agent did and decided.
  
> Each row is an atomic, structured fact about a recruitment action or decision.
> Unlike free-text summaries, these are directly queryable by type/subject/verb.
  
> Fact types:
>   - candidate_action:  Agent viewed/screened/scheduled/offered a candidate
>   - decision:          Screening or evaluation outcome (passed/failed/hired)
>   - preference:        User-stated preference (location, salary, skills)
>   - workflow_state:    Pipeline stage a candidate is in
>   - agent_action:      Non-candidate-specific action (JD generated, search done)
> """
  
> import uuid
> from datetime import datetime
  
> from sqlalchemy import String, Text, DateTime, ForeignKey, Index, JSON
> from sqlalchemy.orm import Mapped, mapped_column
> from sqlalchemy.sql import func
  
> from app.core.database import Base
  
  
> class MemoryFact(Base):
>     __tablename__ = "memory_facts"
  
>     id: Mapped[str] = mapped_column(
>         String(36),
>         primary_key=True,
>         default=lambda: str(uuid.uuid4()),
>     )
>     user_id: Mapped[str] = mapped_column(
>         String(36),
>         ForeignKey("users.id", ondelete="CASCADE"),
>         nullable=False,
>         index=True,
>     )
>     session_id: Mapped[str] = mapped_column(
>         String(255),
>         nullable=False,
>     )
>     fact_type: Mapped[str] = mapped_column(
>         String(50),
>         nullable=False,
>         comment="candidate_action | decision | preference | workflow_state | agent_action",
>     )
>     subject_type: Mapped[str | None] = mapped_column(
>         String(50),
>         nullable=True,
>         comment="candidate | job | application | interview",
>     )
>     subject_id: Mapped[str | None] = mapped_column(
>         String(255),
>         nullable=True,
>     )
>     verb: Mapped[str] = mapped_column(
>         String(50),
>         nullable=False,
>         comment="viewed | screened | scheduled | passed | failed | prefers_* | moved_to | generated_jd | searched | …",
>     )
>     object_value: Mapped[dict | None] = mapped_column(
>         JSON,
>         nullable=True,
>         comment="Structured payload relevant to the verb",
>     )
  
>     created_at: Mapped[datetime] = mapped_column(
>         DateTime(timezone=True), server_default=func.now()
>     )
>     updated_at: Mapped[datetime] = mapped_column(
>         DateTime(timezone=True), server_default=func.now(), onupdate=func.now()
>     )
  
>     __table_args__ = (
>         Index("idx_memory_facts_user_subject", "user_id", "subject_type", "subject_id"),
>         Index("idx_memory_facts_user_type", "user_id", "fact_type"),
>         Index("idx_memory_facts_user_verb", "user_id", "verb"),
>     )
