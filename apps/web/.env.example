# ============================================
# AI Recruitment System — Frontend Configuration
# ============================================
# Copy this file to .env.local and adjust as needed

# Backend API URL (must match backend CORS_ORIGINS)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket URL for v0.6b parse_resume_async 进度推送 (matches NEXT_PUBLIC_API_URL host)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Sentry 客户端遥测 (可选, 空值禁用)
NEXT_PUBLIC_SENTRY_DSN=

