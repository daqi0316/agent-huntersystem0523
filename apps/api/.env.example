# ============================================
# AI Recruitment System — Backend Configuration
# ============================================
# Copy this file to .env and adjust as needed

# App
APP_NAME=AI Recruitment System
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_recruitment
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_recruitment

# Redis (session cache, agent memory)
REDIS_URL=redis://localhost:6379/0

# Qdrant (vector storage for RAG)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=resumes

# MinIO (file/resume storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM Provider
# Options: omlx (local) or vllm (remote)
LLM_PROVIDER=omlx
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=sk-no-key-required
LLM_MODEL=Qwen3.6-35B-A3B-4bit
LLM_EMBED_MODEL=bge-m3-mlx-4bit

# JD Generator
JD_GEN_MAX_ITERATIONS=6
JD_GEN_THRESHOLD=7.0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# WeChat OAuth (企业微信扫码登录) — P5-2
# 默认 mock_mode=True (本地不调企微 API, callback 用固定 mock 用户)
# staging/prod 必须配真凭据 + 设 WECHAT_MOCK_MODE=false
WECHAT_CORP_ID=
WECHAT_CORP_AGENT_ID=
WECHAT_CORP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback
WECHAT_QRCODE_EXPIRE_SECONDS=600
# WECHAT_MOCK_MODE=true

# ── v1.0a: 补缺的 env keys (check_env_keys.py 扫描发现) ──────────────

# External LLM API keys (multi-provider 支持)
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=

# Web search
TAVILY_API_KEY=

# QWeather (天气查询 skill)
QWEATHER_API_KEY=
QWEATHER_API_HOST=devapi.qweather.com

# Sentry (生产环境启用, 空值禁用)
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_TRACES_SAMPLE_RATE=0.0  # 注意: env var 名带空格, CI 难用, 改 SENTRY_TRACES_SAMPLE_RATE

# Feishu webhook (P5-2 企业微信外)
FEISHU_WEBHOOK_URL=

# MCP A/B testing + 监控 (v0.4 引入)
MCP_AB_ENABLED=false
MCP_AB_PERCENT=10
MCP_AB_ALLOWLIST=
MCP_ALERT_ERROR_RATE_THRESHOLD=0.1
MCP_ALERT_RESTART_THRESHOLD=3
MCP_ALERT_WINDOW_SECONDS=60
MCP_LARGE_RESULT_DIR=/tmp/mcp-large-results

# Feature flags
ENABLE_LAYERED_PROMPT=true
EPHEMERAL_ENABLED=true
SKILLS_ENABLED=true
USER_MEMORY_ENABLED=true
RATELIMIT_ROLLOUT_PCT=100

# 注: 代码用 "SENTRY TRACES_SAMPLE_RATE" (带空格, 实际是 typo)
# 推后续 PR 改成 SENTRY_TRACES_SAMPLE_RATE (无空格), v1.0a 暂同步 .env.example
SENTRY TRACES_SAMPLE_RATE=0.0
