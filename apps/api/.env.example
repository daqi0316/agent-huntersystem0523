# ============================================
# AI Recruitment System — Backend Configuration
# ============================================
# Copy this file to .env and adjust as needed

# App
APP_NAME=AI Recruitment System
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_recruitment
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_recruitment

# Redis (session cache, agent memory)
REDIS_URL=redis://localhost:6379/0

# Qdrant (vector storage for RAG)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=resumes

# MinIO (file/resume storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes

# RabbitMQ (async job queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM Provider
# Options: omlx (local) or vllm (remote)
LLM_PROVIDER=omlx
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=sk-no-key-required
LLM_MODEL=Qwen3.6-35B-A3B-4bit
LLM_EMBED_MODEL=bge-m3-mlx-4bit

# JD Generator
JD_GEN_MAX_ITERATIONS=6
JD_GEN_THRESHOLD=7.0

# CORS
CORS_ORIGINS=["http://localhost:3000"]
