{
  "$comment": "MCP server 注册表（V-4 修复：分层配置 + 启动阶段 + 密钥注入）。PR-9b 加 5 server 拆 Type B 业务服务。",
  "servers": [
    {
      "id": "mcp-utils",
      "command": ".venv/bin/python",
      "args": ["-m", "app.mcp_servers.builtin.utils_server"],
      "startup_phase": "core",
      "restart": "on-failure",
      "max_restarts": 5,
      "timeout": 30,
      "capability": "read",
      "version": "1.0.0",
      "env_keys": [],
      "extra_env": {
        "PYTHONUNBUFFERED": "1"
