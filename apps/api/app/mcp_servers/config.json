{
  "$comment": "MCP server 注册表（V-4 修复：分层配置 + 启动阶段 + 密钥注入）",
  "servers": [
    {
      "id": "mcp-utils",
      "command": ".venv/bin/python",
      "args": ["-m", "app.mcp_servers.builtin.utils_server"],
      "startup_phase": "core",
      "restart": "on-failure",
      "max_restarts": 5,
      "timeout": 30,
      "capability": "read",
      "version": "1.0.0",
      "env_keys": [],
      "extra_env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "id": "mcp-weather",
      "command": ".venv/bin/python",
      "args": ["-m", "app.mcp_servers.builtin.weather_server"],
      "startup_phase": "core",
      "restart": "on-failure",
      "max_restarts": 5,
      "timeout": 30,
      "capability": "read",
      "version": "1.0.0",
      "env_keys": [],
      "extra_env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
