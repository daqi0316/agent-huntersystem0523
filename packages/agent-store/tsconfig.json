{
  "extends": "../../packages/config/typescript-config.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "jsx": "preserve",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
