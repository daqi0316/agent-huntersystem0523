{
  "name": "@ai-recruitment/agent-store",
  "version": "1.0.0",
  "private": true,
  "description": "AI 助手的共享状态层：Zustand store + 卡片解析器 + 工具标签映射。供 context-bar 包与 apps/web 共用。",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.mjs",
      "require": "./dist/parser.cjs"
    },
    "./tool-labels": {
      "types": "./dist/tool-labels.d.ts",
      "import": "./dist/tool-labels.mjs",
      "require": "./dist/tool-labels.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .nuxt"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "unbuild": "^3.6.0"
  }
}
