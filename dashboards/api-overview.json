{
  "title": "API Overview",
  "uid": "api-overview",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["api", "mcp", "phase-c-c1"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) by path",
      "description": "sum(rate(api_request_total[5m])) grouped by path. Phase C C1.2 启动. PromQL: sum by (path) (rate(api_request_total[5m]))",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum by (path) (rate(api_request_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 latency (s) by path",
      "description": "histogram_quantile(0.95, ...) on http_request_duration_seconds. Phase C C1.2 启动. PromQL: histogram_quantile(0.95, sum by (le, path) (rate(http_request_duration_seconds_bucket[5m])))",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (5xx/total)",
      "description": "5xx 占比. Phase C C1.2 启动. PromQL: sum(rate(api_request_total{status=~\"5..\"}[5m])) / sum(rate(api_request_total[5m]))",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(api_request_total{status=~\"5..\"}[5m])) / sum(rate(api_request_total[5m]))",
          "legendFormat": "error_rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineColor": "red"}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process CPU rate (cores)",
      "description": "uvicorn process_cpu_seconds_total rate. F8 修: backend 改用 psutil 直接暴露. PromQL: rate(process_cpu_seconds_total[5m])",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "cpu_cores",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineColor": "orange"}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Process memory (RSS bytes)",
      "description": "uvicorn process_resident_memory_bytes. F8 修: backend 改用 psutil 直接暴露. PromQL: process_resident_memory_bytes",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "rss_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineColor": "blue"}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
  ]
}
